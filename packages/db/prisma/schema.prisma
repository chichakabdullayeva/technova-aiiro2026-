generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SOC_ANALYST
  VIEWER
  DEVSECOPS_ENGINEER
}

enum AssetType {
  IOT_SENSOR
  CLOUD_OBJECT
  SERVER
  CAMERA
  WATER_SYSTEM
  NETWORK_DEVICE
  UNKNOWN
}

enum Criticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssetStatus {
  ACTIVE
  ISOLATED
  OFFLINE
}

enum VulnerabilityStatus {
  DETECTED
  ANALYZING
  MITIGATED
  FALSE_POSITIVE
}

enum ScanJobType {
  CONTINUOUS_DISCOVERY
  MICRO_SCAN
  FULL_SCAN
}

enum ScanJobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

enum ScanTrigger {
  ZDI_FEED
  SCHEDULE
  MANUAL
}

enum RemediationType {
  ISOLATION
  VIRTUAL_PATCH
  BOTH
}

enum RemediationStatus {
  PENDING
  APPLIED
  FAILED
  ROLLED_BACK
}

enum IncidentStatus {
  OPEN
  CONTAINED
  RESOLVED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(VIEWER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs AuditLog[]
}

model Asset {
  id           String      @id @default(uuid())
  name         String
  type         AssetType   @default(UNKNOWN)
  ipAddress    String?
  criticality  Criticality @default(MEDIUM)
  status       AssetStatus @default(ACTIVE)
  tags         String[]
  discoveredAt DateTime    @default(now())
  lastSeenAt   DateTime    @default(now())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  vulnerabilities   Vulnerability[]
  scanJobs          ScanJob[]
  isolationActions  RemediationAction[]
}

model ThreatFeedItem {
  id              String   @id @default(uuid())
  source          String   // "trend_micro_zdi" | "manual"
  cveId           String?
  title           String
  description     String
  severity        String   // "CRITICAL" | "HIGH" | "MEDIUM" | "LOW"
  hasOfficialPatch Boolean @default(false)
  publishedAt     DateTime @default(now())
  rawPayload      Json?
  createdAt       DateTime @default(now())

  vulnerabilities Vulnerability[]
  matchedAssets   AssetThreatMatch[]
}

model AssetThreatMatch {
  id              String         @id @default(uuid())
  assetId         String
  threatFeedItemId String
  matchScore      Int            @default(0)
  createdAt       DateTime       @default(now())

  asset          Asset?          @relation(fields: [assetId], references: [id])
  threatFeedItem ThreatFeedItem? @relation(fields: [threatFeedItemId], references: [id])

  @@unique([assetId, threatFeedItemId])
}

model Vulnerability {
  id               String             @id @default(uuid())
  assetId          String
  threatFeedItemId String?
  cvssScore        Float              @default(0)
  epssScore        Float              @default(0)
  criticality      Criticality        @default(MEDIUM)
  confidenceScore  Int                @default(0)
  status           VulnerabilityStatus @default(DETECTED)
  detectedAt       DateTime           @default(now())
  mitigatedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  asset            Asset              @relation(fields: [assetId], references: [id])
  threatFeedItem   ThreatFeedItem?    @relation(fields: [threatFeedItemId], references: [id])
  aiDecisions      AIDecision[]
  remediations     RemediationAction[]
  basSimulations   BasSimulation[]
  incidents        Incident[]
}

model ScanJob {
  id             String         @id @default(uuid())
  type           ScanJobType
  targetAssetId  String?
  status         ScanJobStatus  @default(QUEUED)
  triggeredBy    ScanTrigger    @default(MANUAL)
  progress       Int            @default(0) // 0-100
  resultSummary  String?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime       @default(now())

  targetAsset    Asset?         @relation(fields: [targetAssetId], references: [id])
}

model AIDecision {
  id                String   @id @default(uuid())
  vulnerabilityId   String
  riskScore         Float    @default(0)
  confidenceScore   Int      @default(0)
  recommendedAction String   // "auto_isolate" | "virtual_patch" | "manual_review"
  reasoning         String?
  autoExecute       Boolean  @default(false)
  reviewedBy        String?  // userId
  decidedAt         DateTime @default(now())
  createdAt         DateTime @default(now())

  vulnerability     Vulnerability @relation(fields: [vulnerabilityId], references: [id])
}

model RemediationAction {
  id               String            @id @default(uuid())
  vulnerabilityId  String
  assetId          String?
  type             RemediationType
  targetSystem     String?           // "WAF" | "IPS" | "firewall"
  ruleGenerated    String?
  status           RemediationStatus @default(PENDING)
  appliedAt        DateTime?
  rolledBackAt     DateTime?
  createdAt        DateTime          @default(now())

  vulnerability    Vulnerability     @relation(fields: [vulnerabilityId], references: [id])
  asset            Asset?            @relation(fields: [assetId], references: [id])
  wafIpsRules      WafIpsRule[]
}

model WafIpsRule {
  id                   String          @id @default(uuid())
  remediationActionId  String
  ruleType             String          // "regex" | "signature"
  ruleBody             String
  deployedTo           String?
  active               Boolean         @default(true)
  createdAt            DateTime        @default(now())

  remediationAction    RemediationAction @relation(fields: [remediationActionId], references: [id])
}

model BasSimulation {
  id               String   @id @default(uuid())
  vulnerabilityId  String
  scenario         String?
  result           String   // "confirmed_exploitable" | "not_exploitable" | "inconclusive"
  ranAt            DateTime @default(now())
  createdAt        DateTime @default(now())

  vulnerability    Vulnerability @relation(fields: [vulnerabilityId], references: [id])
}

model DevSecOpsScan {
  id              String   @id @default(uuid())
  repoOrPipeline  String
  iacTool         String   // "terraform" | "ansible" | "kubernetes"
  findings        Json?
  blockedDeploy   Boolean  @default(false)
  scannedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
}

model Incident {
  id               String             @id @default(uuid())
  vulnerabilityId  String
  title            String
  status           IncidentStatus     @default(OPEN)
  timeline         Json?
  createdAt        DateTime           @default(now())
  resolvedAt       DateTime?
  updatedAt        DateTime           @updatedAt

  vulnerability    Vulnerability      @relation(fields: [vulnerabilityId], references: [id])
  reports          IncidentReport[]
  knowledgeBaseEntries KnowledgeBaseEntry[]
}

model IncidentReport {
  id            String   @id @default(uuid())
  incidentId    String
  generatedBy   String   // "llm" | "template"
  content       String   // markdown
  createdAt     DateTime @default(now())

  incident      Incident @relation(fields: [incidentId], references: [id])
}

model KnowledgeBaseEntry {
  id               String   @id @default(uuid())
  pattern          String
  description      String?
  sourceIncidentId String?
  autoApplyRule    Json?
  timesReused      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sourceIncident   Incident? @relation(fields: [sourceIncidentId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  details    Json?
  timestamp  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id])
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}
